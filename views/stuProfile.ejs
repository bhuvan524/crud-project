<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students data</title>
</head>
<body>
    <h1>data here</h1>
    <table border="1">
        <tr>
            <td>name</td>
            <td>branch</td>
            <td>rollNo</td>
            <td>email</td>
            <td>Operation</td>
        </tr>
        <% students.forEach(students =>{%>
            <tr>
                <td><%= students.name %></td>
                <td><%= students.branch %></td>
                <td><%= students.rollNo %></td>
                <td><%= students.emil %></td>
                <td><a href="/ui/delete/<%= students._id %>">delete</a></td>
            </tr>
        <% }) %>
         
    </table>
</body>
</html>